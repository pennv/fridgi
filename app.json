{
  "expo": {
    "name": "Fridgi",
    "slug": "fridgi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fridgi.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Fridgi needs camera access to scan receipts and barcodes."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#000000"
      },
      "package": "com.fridgi.app",
      "permissions": ["android.permission.CAMERA"]
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Fridgi needs camera access to scan receipts and barcodes."
        }
      ]
    ]
  }
}
